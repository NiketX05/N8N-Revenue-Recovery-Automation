# ============================================================
# Failed Payments + Churn Saver v2.1 — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# These variables map to n8n's Settings → Variables panel.
# Do NOT commit your real .env file to version control.
# ============================================================

# --- Stripe ---
# Webhook Signing Secret from Stripe → Developers → Webhooks
STRIPE_SIGNING_SECRET=whsec_your_signing_secret_here

# Your Stripe Customer Portal URL (customers are redirected here to update payment methods)
STRIPE_PORTAL_URL=https://billing.stripe.com/p/login/your_portal_id

# --- Supabase ---
# Found in Supabase → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Email (SMTP) ---
# The "From" address shown to customers
SENDER_EMAIL=Billing Team <billing@yourcompany.com>

# Where customer replies are directed
REPLY_TO_EMAIL=support@yourcompany.com

# --- Slack ---
# Channel where billing alerts are posted (include the #)
SLACK_BILLING_CHANNEL=#billing-alerts

# --- Dunning Wait Times (in minutes) ---
# How long to wait before sending each dunning stage email.
# These control the delay AFTER each corresponding Stripe webhook event.
DUNNING_WAIT_STAGE_1=240    # Stage 1: 4 hours (friendly reminder)
DUNNING_WAIT_STAGE_2=60     # Stage 2: 1 hour  (update card request)
DUNNING_WAIT_STAGE_3=1440   # Stage 3: 24 hours (urgent warning)
DUNNING_WAIT_STAGE_4=4320   # Stage 4: 72 hours (final / win-back)
